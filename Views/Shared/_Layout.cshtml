<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TiendaVirtualYanten</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-primary mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="Producto" asp-action="Tienda">🛒 TiendaYanten</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Producto" asp-action="Tienda">Tienda</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Categoria" asp-action="Index">Categorías</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Producto" asp-action="Index">Admin Productos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Usuario" asp-action="Index">Usuarios</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Rol" asp-action="Index">Roles</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav align-items-center">
                        @{
                            var carritoCount = 0;
                            try { carritoCount = (int)(ViewBag.CarritoCount ?? 0); } catch { }
                        }
                        <li class="nav-item me-2">
                            <a class="nav-link text-white position-relative" asp-controller="Carrito" asp-action="Index">
                                🛒
                                @if (carritoCount > 0)
                                {
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                        @carritoCount
                                    </span>
                                }
                            </a>
                        </li>
                        @if (Context.Session.GetString("UsuarioNombre") != null)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-white">
                                    👤 @Context.Session.GetString("UsuarioNombre")
                                    <span class="badge bg-light text-dark ms-1">@Context.Session.GetString("UsuarioRol")</span>
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Login" asp-action="Logout">Cerrar sesión</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container">
            &copy; 2026 - TiendaVirtualYanten
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
