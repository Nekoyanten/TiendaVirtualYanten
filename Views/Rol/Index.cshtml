@model List<TiendaVirtualYanten.Models.Rol>

@{
    ViewData["Title"] = "Roles";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Lista de Roles</h2>
        <a class="btn btn-primary" asp-action="Create">Nuevo Rol</a>
    </div>

    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Descripción</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td><span class="badge bg-secondary">@item.Nombre</span></td>
                    <td>@item.Descripcion</td>
                    <td>
                        <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@item.Id">Editar</a>
                        <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.Id"
                           onclick="return confirm('¿Eliminar este rol?')">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
