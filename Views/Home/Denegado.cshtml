@{
    ViewData["Title"] = "Acceso denegado";
}
<div class="container mt-5 text-center">
    <div class="card border-danger mx-auto" style="max-width: 500px;">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">🚫 Acceso denegado</h4>
        </div>
        <div class="card-body">
            <p class="mt-3">No tienes permisos para realizar esta acción.</p>
            <p class="text-muted">Contacta al administrador si crees que esto es un error.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Volver al inicio</a>
        </div>
    </div>
</div>

