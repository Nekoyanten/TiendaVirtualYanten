@model TiendaVirtualYanten.Models.Usuario

@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="container mt-4">
    <h2>Editar Usuario</h2>
    <hr />

    <div class="row">
        <div class="col-md-5">
            <form asp-action="Edit" method="post">

                <input type="hidden" asp-for="Id" />

                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Nombre" class="form-label"></label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Correo" class="form-label"></label>
                    <input asp-for="Correo" class="form-control" type="email" />
                    <span asp-validation-for="Correo" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Celular" class="form-label"></label>
                    <input asp-for="Celular" class="form-control" placeholder="3XXXXXXXXX" />
                    <span asp-validation-for="Celular" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" type="password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="RolId" class="form-label">Rol</label>
                    <select asp-for="RolId" class="form-control">
                        <option value="">-- Seleccione un rol --</option>
                        @foreach (var rol in ViewBag.Roles)
                        {
                            <option value="@rol.Id">@rol.Nombre</option>
                        }
                    </select>
                    <span asp-validation-for="RolId" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">Actualizar</button>
                <a asp-action="Index" class="btn btn-secondary">Volver</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
