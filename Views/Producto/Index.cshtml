@model List<TiendaVirtualYanten.Models.Producto>

@{
    ViewData["Title"] = "Productos";
    var puedeCrear = ViewBag.PuedeCrear as bool? ?? false;
    var puedeEditar = ViewBag.PuedeEditar as bool? ?? false;
    var puedeEliminar = ViewBag.PuedeEliminar as bool? ?? false;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Lista de Productos</h2>
        @if (puedeCrear)
        {
            <a class="btn btn-primary" asp-action="Create">Nuevo Producto</a>
        }
    </div>

    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Nombre</th>
                <th>Precio</th>
                <th>Stock</th>
                <th>Categoría</th>
                <th>Estado</th>
                @if (puedeEditar || puedeEliminar)
                {
                    <th>Acciones</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Nombre</td>
                    <td>$@item.Precio.ToString("N2")</td>
                    <td>@item.Stock</td>
                    <td>@item.Categoria?.Nombre</td>
                    <td>
                        @if (item.TieneStock())
                        {
                            <span class="badge bg-success">En stock</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Agotado</span>
                        }
                    </td>
                    @if (puedeEditar || puedeEliminar)
                    {
                        <td>
                            @if (puedeEditar)
                            {
                                <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@item.Id">Editar</a>
                            }
                            @if (puedeEliminar)
                            {
                                <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.Id"
                                   onclick="return confirm('¿Eliminar este producto?')">Eliminar</a>
                            }
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>
