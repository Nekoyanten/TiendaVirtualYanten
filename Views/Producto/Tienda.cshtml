@model List<TiendaVirtualYanten.Models.Producto>

@{
    ViewData["Title"] = "Tienda";
}

<div class="container mt-4">

    <div class="row mb-4">
        <div class="col-12">
            <form method="get" asp-action="Tienda" class="d-flex gap-2 flex-wrap align-items-center">
                <input type="text" name="buscar" value="@ViewBag.Buscar"
                       class="form-control" style="max-width:280px" placeholder="🔍 Buscar producto..." />
                <select name="categoriaId" class="form-select" style="max-width:200px">
                    <option value="">Todas las categorías</option>
                    @foreach (var cat in ViewBag.Categorias)
                    {
                        <option value="@cat.Id" selected="@(ViewBag.CategoriaId==cat.Id ? "selected" : null)">
                            @cat.Nombre
                        </option>
                    }
                </select>
                <button type="submit" class="btn btn-primary">Filtrar</button>
                <a asp-action="Tienda" class="btn btn-outline-secondary">Limpiar</a>
            </form>
        </div>
    </div>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <h4 class="text-muted">No se encontraron productos</h4>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
            @foreach (var producto in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0">
                        <a asp-action="Detalle" asp-route-id="@producto.Id">
                            @if (!string.IsNullOrEmpty(producto.ImagenUrl))
                            {
                                <img src="@producto.ImagenUrl" class="card-img-top"
                                     style="height:200px;object-fit:cover;" alt="@producto.Nombre" />
                            }
                            else
                            {
                                <div class="card-img-top bg-light d-flex align-items-center justify-content-center"
                                     style="height:200px;">
                                    <span style="font-size:3rem;">🛍️</span>
                                </div>
                            }
                        </a>
                        <div class="card-body d-flex flex-column">
                            <span class="badge bg-secondary mb-1" style="width:fit-content;">
                                @producto.Categoria?.Nombre
                            </span>
                            <h6 class="card-title fw-bold mb-1">@producto.Nombre</h6>
                            @if (!string.IsNullOrEmpty(producto.Descripcion))
                            {
                                <p class="card-text text-muted small mb-2"
                                   style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                                    @producto.Descripcion
                                </p>
                            }
                            <div class="mt-auto">
                                <p class="fs-5 fw-bold text-primary mb-2">$@producto.Precio.ToString("N2")</p>
                                @if (producto.TieneStock())
                                {
                                    <span class="badge bg-success mb-2">En stock (@producto.Stock)</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger mb-2">Agotado</span>
                                }
                                <div class="d-flex gap-2">
                                    <a asp-action="Detalle" asp-route-id="@producto.Id"
                                       class="btn btn-outline-primary btn-sm flex-grow-1">
                                        Ver detalle
                                    </a>
                                    @if (producto.TieneStock())
                                    {
                                        <form asp-controller="Carrito" asp-action="Agregar" method="post" class="flex-grow-1">
                                            <input type="hidden" name="productoId" value="@producto.Id" />
                                            <input type="hidden" name="cantidad" value="1" />
                                            <button type="submit" class="btn btn-primary btn-sm w-100">
                                                🛒 Agregar
                                            </button>
                                        </form>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
